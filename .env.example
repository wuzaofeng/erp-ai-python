### 
# ===================== 服务配置 =====================

# 服务监听端口（默认 3001）
PORT=3001

# 运行环境：development | production
ENV=production

# ===================== ERP 配置 =====================

# ERP 后端地址
ERP_BASE_URL=http://10.35.110.70:9090

# ERP 必需的请求头（按实际环境调整）
ERP_LANGUAGE=zh-CN
ERP_TIMEZONE=Asia/Shanghai
ERP_UTC_OFFSET=-480

# ===================== 安全配置 =====================

# Key 加密用的密钥（32位随机字符串，生产环境务必更换！）
ENCRYPTION_SECRET=your-32-char-secret-key-here-1234

# ===================== AI 模型配置 =====================

# 默认使用的 AI 模型
DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# 最大工具调用轮次（防 Agent 死循环）
MAX_TOOL_ROUNDS=3

# OpenRouter Referer（可选）
OPENROUTER_REFERER=http://localhost:8000

# ===================== RAG 配置 =====================

# 触发 RAG 的最小行数（小于此值全量传给 AI）
RAG_THRESHOLD=30

# RAG 最多传给 AI 的行数
RAG_MAX_ROWS=20

# ===================== 缓存配置 =====================

# 查询结果缓存 TTL（毫秒），默认 5 分钟
QUERY_CACHE_TTL_MS=300000

# 缓存最大条数
QUERY_CACHE_MAX_SIZE=200

# ===================== 内存配置 =====================

# 每个用户保留的最大历史消息条数（一问一答算 2 条）
MAX_HISTORY_MESSAGES=20
